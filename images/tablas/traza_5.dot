digraph G {
  node [shape=plaintext];
  struct1 [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
      <TR><TD BGCOLOR="lightgray" COLSPAN="4"><B>Traza LL(1) - Sentencia 5: prinplup ( x ) ;</B></TD></TR>
      <TR><TD BGCOLOR="#1F618D"><FONT COLOR="white"><B>Paso</B></FONT></TD><TD BGCOLOR="#1F618D"><FONT COLOR="white"><B>Pila</B></FONT></TD><TD BGCOLOR="#1F618D"><FONT COLOR="white"><B>Entrada</B></FONT></TD><TD BGCOLOR="#1F618D"><FONT COLOR="white"><B>Acción</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#EBF5FB">1</TD><TD BGCOLOR="#EBF5FB">$ programa</TD><TD BGCOLOR="#EBF5FB">PRINPLUP ZACIAN INDEEDEE ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#EBF5FB">programa -&gt; sentencia sentencia_rest</TD></TR>
      <TR><TD BGCOLOR="#D6EAF8">2</TD><TD BGCOLOR="#D6EAF8">$ sentencia_rest sentencia</TD><TD BGCOLOR="#D6EAF8">PRINPLUP ZACIAN INDEEDEE ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#D6EAF8">sentencia -&gt; impresion</TD></TR>
      <TR><TD BGCOLOR="#EBF5FB">3</TD><TD BGCOLOR="#EBF5FB">$ sentencia_rest impresion</TD><TD BGCOLOR="#EBF5FB">PRINPLUP ZACIAN INDEEDEE ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#EBF5FB">impresion -&gt; PRINPLUP ZACIAN expr ZAMAZENTA PANCHAM</TD></TR>
      <TR><TD BGCOLOR="#D6EAF8">4</TD><TD BGCOLOR="#D6EAF8">$ sentencia_rest PANCHAM ZAMAZENTA expr ZACIAN PRINPLUP</TD><TD BGCOLOR="#D6EAF8">PRINPLUP ZACIAN INDEEDEE ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#D6EAF8">Match PRINPLUP</TD></TR>
      <TR><TD BGCOLOR="#EBF5FB">5</TD><TD BGCOLOR="#EBF5FB">$ sentencia_rest PANCHAM ZAMAZENTA expr ZACIAN</TD><TD BGCOLOR="#EBF5FB">ZACIAN INDEEDEE ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#EBF5FB">Match ZACIAN</TD></TR>
      <TR><TD BGCOLOR="#D6EAF8">6</TD><TD BGCOLOR="#D6EAF8">$ sentencia_rest PANCHAM ZAMAZENTA expr</TD><TD BGCOLOR="#D6EAF8">INDEEDEE ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#D6EAF8">expr -&gt; termino expr_rest</TD></TR>
      <TR><TD BGCOLOR="#EBF5FB">7</TD><TD BGCOLOR="#EBF5FB">$ sentencia_rest PANCHAM ZAMAZENTA expr_rest termino</TD><TD BGCOLOR="#EBF5FB">INDEEDEE ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#EBF5FB">termino -&gt; INDEEDEE</TD></TR>
      <TR><TD BGCOLOR="#D6EAF8">8</TD><TD BGCOLOR="#D6EAF8">$ sentencia_rest PANCHAM ZAMAZENTA expr_rest INDEEDEE</TD><TD BGCOLOR="#D6EAF8">INDEEDEE ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#D6EAF8">Match INDEEDEE</TD></TR>
      <TR><TD BGCOLOR="#EBF5FB">9</TD><TD BGCOLOR="#EBF5FB">$ sentencia_rest PANCHAM ZAMAZENTA expr_rest</TD><TD BGCOLOR="#EBF5FB">ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#EBF5FB">expr_rest -&gt; epsilon</TD></TR>
      <TR><TD BGCOLOR="#D6EAF8">10</TD><TD BGCOLOR="#D6EAF8">$ sentencia_rest PANCHAM ZAMAZENTA</TD><TD BGCOLOR="#D6EAF8">ZAMAZENTA PANCHAM $</TD><TD BGCOLOR="#D6EAF8">Match ZAMAZENTA</TD></TR>
      <TR><TD BGCOLOR="#EBF5FB">11</TD><TD BGCOLOR="#EBF5FB">$ sentencia_rest PANCHAM</TD><TD BGCOLOR="#EBF5FB">PANCHAM $</TD><TD BGCOLOR="#EBF5FB">Match PANCHAM</TD></TR>
      <TR><TD BGCOLOR="#D6EAF8">12</TD><TD BGCOLOR="#D6EAF8">$ sentencia_rest</TD><TD BGCOLOR="#D6EAF8">$</TD><TD BGCOLOR="#D6EAF8">sentencia_rest -&gt; epsilon</TD></TR>
      <TR><TD BGCOLOR="#EBF5FB">13</TD><TD BGCOLOR="#EBF5FB">$</TD><TD BGCOLOR="#EBF5FB">$</TD><TD BGCOLOR="#EBF5FB">ACEPTAR</TD></TR>
    </TABLE>
  >];
}
