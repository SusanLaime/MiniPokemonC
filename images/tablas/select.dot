      <TR><TD>bucle_for -&gt; FORRETRESS ZACIAN VAROOM INDEEDEE SEEL expr PANCHAM condicion PANCHAM INDEEDEE SEEL expr ZAMAZENTA bloque </TD><TD>FORRETRESS </TD></TR>
      <TR><TD>sentencia_control -&gt; BRAIXEN PANCHAM </TD><TD>BRAIXEN </TD></TR>
      <TR><TD>sentencia_control -&gt; TINGLU PANCHAM </TD><TD>TINGLU </TD></TR>
      <TR><TD>condicion -&gt; expr op_rel expr </TD><TD>NUMEL INDEEDEE </TD></TR>
      <TR><TD>op_rel -&gt; QUAQUAVAL </TD><TD>QUAQUAVAL </TD></TR>
      <TR><TD>op_rel -&gt; GREEDENT </TD><TD>GREEDENT </TD></TR>
      <TR><TD>op_rel -&gt; LEDIAN </TD><TD>LEDIAN </TD></TR>
