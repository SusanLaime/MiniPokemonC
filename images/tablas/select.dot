      <TR><TD>decl_var -&gt; VAROOM INDEEDEE SEEL expr PANCHAM </TD><TD>VAROOM </TD></TR>
      <TR><TD>asignacion -&gt; INDEEDEE SEEL expr PANCHAM </TD><TD>INDEEDEE </TD></TR>
      <TR><TD>impresion -&gt; PRINPLUP ZACIAN expr ZAMAZENTA PANCHAM </TD><TD>PRINPLUP </TD></TR>
      <TR><TD>condicional -&gt; INCINEROAR ZACIAN condicion ZAMAZENTA bloque else_opt </TD><TD>INCINEROAR </TD></TR>
      <TR><TD>else_opt -&gt; ELEKID bloque </TD><TD>ELEKID </TD></TR>
      <TR><TD>else_opt -&gt; epsilon </TD><TD>VAROOM INDEEDEE PRINPLUP INCINEROAR GARDEVOIR WAILMER FORRETRESS BRAIXEN TINGLU $ GALLADE </TD></TR>
      <TR><TD>bloque -&gt; GARDEVOIR sentencias_bloque GALLADE </TD><TD>GARDEVOIR </TD></TR>
