digraph G {
  node [shape=plaintext];
  struct1 [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
      <TR><TD BGCOLOR="lightblue"><B>Producción</B></TD><TD BGCOLOR="lightblue"><B>SELECT</B></TD></TR>
      <TR><TD>programa -&gt; sentencia sentencia_rest </TD><TD>VAROOM INDEEDEE PRINPLUP INCINEROAR GARDEVOIR WAILMER FORRETRESS BRAIXEN TINGLU </TD></TR>
      <TR><TD>sentencia_rest -&gt; sentencia sentencia_rest </TD><TD>VAROOM INDEEDEE PRINPLUP INCINEROAR GARDEVOIR WAILMER FORRETRESS BRAIXEN TINGLU </TD></TR>
      <TR><TD>sentencia_rest -&gt; epsilon </TD><TD>$ </TD></TR>
